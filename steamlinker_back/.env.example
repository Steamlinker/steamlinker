# ── Entorno ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Orígenes permitidos (separados por coma). En producción: tu web + dominio del admin.
# Ejemplo producción: https://app.steamlinker.com,https://admin.steamlinker.com
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000

# ── Base de datos ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=steamlinker
DB_USER=postgres
DB_PASSWORD=tu_password

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=genera_un_secreto_largo_minimo_32_caracteres
SESSION_SECRET=tu_secreto_de_sesion

# ── Steam Web API (obligatorio en producción para comparar bibliotecas) ──
STEAM_API_KEY=TU_STEAM_API_KEY

# ── Producción (recomendado) ─────────────────────────────────────
# NODE_ENV=production
# APP_URL=https://api.tudominio.com
# CORS_ORIGINS=https://app.tudominio.com
# Usar HTTPS delante del Node (nginx, Caddy, cloud load balancer)
